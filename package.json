{
  "name": "kickstart-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint ./src",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "biome:fix": "biome check --fix .",
    "biome:check": "biome check .",
    "biome:ci": "biome ci .",
    "model:import": "npx tsx ./scripts/importProject.ts",
    "preview": "vite preview",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "codegen:check": "graphql-codegen --config codegen.ts --check"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "@kontent-ai/rich-text-resolver": "^2.0.2",
    "@portabletext/react": "^4.0.3",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/react-query": "^5.90.1",
    "dotenv": "^17.2.2",
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-router-dom": "^7.12.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.0",
    "@biomejs/biome": "^2.3.13",
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/client-preset": "^5.0.1",
    "@graphql-codegen/introspection": "^5.0.0",
    "@kontent-ai/biome-config": "^0.7.0",
    "@kontent-ai/data-ops": "^2.3.9",
    "@kontent-ai/eslint-config": "^2.3.0",
    "@parcel/watcher": "^2.5.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.25.1",
    "typescript": "~5.8.3",
    "vite": "^7.1.11"
  }
}
