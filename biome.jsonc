{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@kontent-ai/biome-config/base", "@kontent-ai/biome-config/react"],
  "files": {
    "includes": [
      "!**/*.css",
      "!src/graphql/gql.ts",
      "!src/graphql/graphql.ts",
      "!src/graphql/index.ts"
    ]
  },
  "linter": {
    "rules": {
      "a11y": {
        "useValidAnchor": "off"
      }
    }
  }
}
